@page "/form-solicitante"
@using MudBlazor
@inject HttpClient Http
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ProtectedSessionStorage SessionStorage
@inject IHttpContextAccessor HttpContextAccessor
@using SistemaLicencias.SHARED.DTOs
@inject SessionService servicess

<MudContainer MaxWidth="MaxWidth.Large" Class="my-4 mx-auto">
    <MudPaper Class="pa-6 mx-auto" Elevation="2" Style="border-radius: 16px;">
        <MudForm @ref="form">
            <MudText Typo="Typo.h5" Class="mb-2 text-primary">📄 Datos del Solicitante</MudText>
            <MudDivider Class="mb-4" />

            <MudGrid Spacing="3">
                <MudItem xs="12" sm="6">
                    <MudSelect T="int" Label="Tipo de Documento" @bind-Value="modelo.TipoDoc" Variant="Variant.Outlined" Required="true">
                        <MudSelectItem Value="0" Disabled="true">Seleccione:</MudSelectItem>
                        <MudSelectItem Value="1">DNI</MudSelectItem>
                        <MudSelectItem Value="4">RUC</MudSelectItem>
                    </MudSelect>
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Label="Nro. Documento"
                                  @bind-Value="modelo.nrodni"
                                  MaxLength="8"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="El DNI es obligatorio." />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Label="Nombres Completos"
                                  @bind-Value="modelo.nombre"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Este campo es obligatorio." />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Label="Dirección Fiscal"
                                  @bind-Value="modelo.direccionFiscal"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  RequiredError="Este campo es obligatorio."
                                  Placeholder="Ej. Av. Las Flores" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Label="Teléfono"
                                  @bind-Value="modelo.telefono"
                                  Variant="Variant.Outlined"
                                  Required="true"
                                  MaxLength="9"
                                  RequiredError="Este campo es obligatorio."
                                  Placeholder="Ej. 987654321" />
                </MudItem>

                <MudItem xs="12" sm="6">
                    <MudTextField Label="E-mail"
                                  @bind-Value="modelo.correo"
                                  Variant="Variant.Outlined"
                                  Placeholder="ejemplo@correo.com" />
                </MudItem>


                <MudItem xs="12" sm="6">
                    <MudCheckBox T="bool"
                                 @bind-value="TieneDiscapacidad"
                                 Label="¿Tiene alguna discapacidad?"
                                 Color="Color.Primary" />

                </MudItem>

                @if(TieneDiscapacidad) {
                    <MudItem xs="12" sm="6">
                        <MudCollapse Expanded="true">
                            <MudTextField Label="N° Carnet CONADIS"
                                          @bind-Value="modelo.nroConadis"
                                          Variant="Variant.Outlined"
                                          Placeholder="Ej. 12345678-9"
                                         />
                        </MudCollapse>
                    </MudItem>
                }

                <MudCheckBox T="bool"
                             Label="¿Pertenece al distrito de Ate?"
                             Color="Color.Primary"
                             @bind-Value="PerteneceDistrito" />



            </MudGrid>

            <MudDivider Class="my-4" />

            <div class="d-flex justify-center">
                @if(cargando) {
                    <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                }
                else {
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="EnviarFormulario">
                        Enviar
                    </MudButton>
                }
            </div>
        </MudForm>
    </MudPaper>
</MudContainer>

