                                </MudItem>

                                <!-- Bloque: Documentos de estructura (tipologías 2,3,6,7) -->
                                @if(new[] { "2", "3", "6", "7" }.Contains(_u.idTipologias)) {
                                    <MudDivider Class="my-3 divider-soft" />
                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck20" T="bool" Class="dense-checkbox"
                                                     Label="Plano de ubicación a escala 1/500 o 1/250 (RNE), con coordenadas UTM WGS84 del elemento y distancia de la arista más saliente al borde exterior de la pista, suscrito por arquitecto colegiado." />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck21" T="bool" Class="dense-checkbox"
                                                     Label="Para EPE en azoteas y fachadas: plano de elevación de fachada donde se aprecie la proporción entre fachada y elemento publicitario, suscrito por arquitecto colegiado." />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck22" T="bool" Class="dense-checkbox"
                                                     Label="Memoria descriptiva de estructuras, suscrita por Ingeniero Civil." />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck23" T="bool" Class="dense-checkbox"
                                                     Label="Plano de estructuras a escala 1/75 o 1/100." />
                                    </MudItem>
                                }

                                <!-- Bloque: Instalaciones eléctricas (tipologías 2,3,4) -->
                                @if(new[] { "2", "3", "4" }.Contains(_u.idTipologias)) {
                                    <MudDivider Class="my-3 divider-soft" />

                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck24" T="bool" Class="dense-checkbox"
                                                     Label="Memoria descriptiva con especificaciones técnicas, suscrita por Ing. Electricista o Mecánico Electricista." />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck25" T="bool" Class="dense-checkbox"
                                                     Label="Plano de instalaciones eléctricas a escala 1/75 o 1/100, suscrito por Ing. Electricista o Mecánico Electricista." />
                                    </MudItem>
                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck26" T="bool" Class="dense-checkbox"
                                                     Label="Solicitud/carta de factibilidad de servicio eléctrico a la empresa prestadora del servicio." />
                                    </MudItem>
                                }

                                <!-- Bloque: Temporalidad / colindantes (tipologías 1,9) -->
