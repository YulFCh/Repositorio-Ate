                                                     Label="Para elementos en exteriores (laterales) de bienes de dominio privado: autorización expresa del propietario colindante del inmueble." />
                                    </MudItem>
                                }
                            </MudGrid>
                        }
                    </div>
                </MudTabPanel>
                *@
                <MudTabPanel Text="REQUISITOS">
                    @if(cargando) {
                        <div class="d-flex justify-center my-5">
                            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
                            <MudText Class="ml-3" Typo="Typo.subtitle1">Cargando requisitos...</MudText>
                        </div>
                    }
                    else if(lstRequisitos == null || lstRequisitos.Count == 0) {
                        <MudText Color="Color.Error" Typo="Typo.subtitle2">
                            No se encontraron requisitos para los parámetros indicados.
                        </MudText>
                    }
                    else {
                        <MudPaper Class="p-4" Elevation="0">
                            <MudText Typo="Typo.h6" GutterBottom="true">Listado de Requisitos</MudText>

                            <MudGrid Spacing="1">
                                @foreach(var req in lstRequisitos) {
                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Value="@req.Estado"
                                                     Label="@req.Nombre"
                                                     Color="Color.Primary"
                                                     Dense="true" />
                                    </MudItem>
                                }
                            </MudGrid>
                        </MudPaper>
                    }
                </MudTabPanel>

            </MudTabs>
            <div class="d-flex align-center justify-space-between">
                <MudButton Variant="Variant.Filled" Color="Color.Success" Class="ml-auto" onclick="Submit">GUARDAR</MudButton>
            </div>
        </MudForm>
    </MudPaper>
</MudContainer>