                                    <MudDivider Class="my-3 divider-soft" />

                                    <MudItem xs="12">
                                        <MudCheckBox @bind-Checked="ck27" T="bool" Class="dense-checkbox"
                                                     Label="Documento simple del solicitante indicando el tiempo de exhibición (máximo 6 meses)." />
                                    </MudItem>
                                    <MudItem xs="12">
