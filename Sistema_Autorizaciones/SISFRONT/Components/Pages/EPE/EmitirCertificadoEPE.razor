@page "/emitircertepe"
@using MudBlazor
@inject HttpClient Http
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ProtectedSessionStorage SessionStorage
@inject IHttpContextAccessor HttpContextAccessor
@inject SessionService sessions
@inject IJSRuntime JS
@using SistemaLicencias.SHARED.DTOs
@using SISFRONT.Components.Utilities;
@using SISFRONT.Components.Dialogs;


<MudContainer MaxWidth="MaxWidth.False" Class="mt-10 px-6 mb-4">
    <MudPaper Class="p-6 mx-auto shadow-md rounded-2xl" Elevation="0">
        <MudText Typo="Typo.h5" Class="mb-6 text-center fw-bold text-primary">
            📋 Listado de Solicitudes EPE Registradas
        </MudText>

        @if(isLoading) {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" Class="d-block mx-auto my-6" />
        }
        else if(lstanuncio is not null && lstanuncio.Any()) {
            <MudTable Items="filteredTable"
                      Hover="true"
                      Bordered="true"
                      Dense="true"
                      Elevation="1"
                      Breakpoint="Breakpoint.Sm"
                      Class="rounded-lg shadow-sm text-sm"
                      Style="font-size: 9px;">

                <ToolBarContent>
                    <MudText Typo="Typo.subtitle2" Class="fw-bold">Total: @lstanuncio.Count registro(s)</MudText>
                    <MudSpacer />
                    <MudTextField T="string" Placeholder="Buscar por N°. Autorizacion o solicitante" @bind-Value="searchTerm"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Class="me-4" />
                </ToolBarContent>

                <HeaderContent>
                    <MudTh>N° Autorización</MudTh>
                    <MudTh>N° Expediente</MudTh>
                    <MudTh>N° Resolución</MudTh>
                    <MudTh>Solicitante</MudTh>
                    <MudTh>TipoSolicitud</MudTh>
                    <MudTh>Fec.Registro</MudTh>
                    <MudTh>Firma</MudTh>
                    <MudTh class="text-center">Opciones</MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd>@context.nroAutorizacion</MudTd>
                    <MudTd>@context.nroExpediente - @context.fechaExpediente </MudTd>
                    <MudTd>@context.nroResolucion - @context.fechaResolucion</MudTd>
                    <MudTd>@context.nombre</MudTd>
                    <MudTd>@context.TipoSolicitud</MudTd>
                    <MudTd>@context.fechaRegistro.ToString("dd/MM/yyyy")</MudTd>
                    <MudTd>
                        @if(context.firma == "SI") {
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" />
                        }
                        else {
                            <MudIcon Icon="@Icons.Material.Filled.Cancel" Color="Color.Error" />
                        }
                    </MudTd>

                    <MudTd Class="text-center">
                        <MudTooltip Text="Abrir Carpeta">
                            <MudIconButton Icon="@Icons.Material.Filled.FolderOpen"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           Class="ms-1"
                                           OnClick="() => GetDialogDocument(context.idAnuncio)" />
                        </MudTooltip>

                        <MudTooltip Text="Ver Imagen">
                            <MudIconButton Icon="@Icons.Material.Filled.Visibility"
                                           Color="Color.Info"
                                           Size="Size.Small"
                                           Class="ms-1"
                                           OnClick="() => GetDialogImg(context.idAnuncio)" />
                        </MudTooltip>

                        <!--
                        <MudTooltip Text="Anular">
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Class="ms-1"
                                           Disabled="@isBtnDisable"
                                           OnClick="() => MostrarDialogoDesactivar(context.idSolicitud)" />

                        </MudTooltip>
                        -->
                    </MudTd>
                </RowTemplate>

                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                </PagerContent>
            </MudTable>

        }
        else {
            <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="text-center">
                No se encontraron registros disponibles.
            </MudAlert>
        }
    </MudPaper>
</MudContainer>

