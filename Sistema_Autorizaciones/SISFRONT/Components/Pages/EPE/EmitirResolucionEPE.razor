@page "/emitirresepe"
@using MudBlazor
@inject HttpClient Http
@inject IDialogService DialogService
@inject NavigationManager Navigation
@inject ProtectedSessionStorage SessionStorage
@inject IHttpContextAccessor HttpContextAccessor
@inject SessionService sessions
@inject IJSRuntime JS
@using SistemaLicencias.SHARED.DTOs
@using SISFRONT.Components.Utilities;
@using SISFRONT.Components.Dialogs;
@using System.Text.RegularExpressions

<MudContainer MaxWidth="MaxWidth.False" Class="mt-10 px-6 mb-4">
    <MudPaper Class="p-6 mx-auto shadow-md rounded-2xl" Elevation="0" Style="max-width:1600px;">
        <MudText Typo="Typo.h5" Class="mb-6 text-center fw-bold text-primary">
            📋 Listado de Solicitudes Pendientes EPE
        </MudText>

        @if(isLoading) {
            <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" Class="d-block mx-auto my-6" />
        }
        else if(anuncio is not null && anuncio.Any()) {
            <MudTable Items="anuncio"
                      Hover="true"
                      Bordered="true"
                      Dense="true"
                      Elevation="1"
                      Breakpoint="Breakpoint.Sm"
                      Class="rounded-lg shadow-sm" Typo="">



                <ToolBarContent>
                    <MudText Typo="Typo.subtitle2" Class="fw-bold">Total: @anuncio.Count registro(s)</MudText>
                    <MudSpacer />
                    <MudTextField T="string" Placeholder="Buscar por N°. Autorizacion o solicitante" @bind-Value="searchTerm"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Class="me-4" />
                </ToolBarContent>

                <HeaderContent>

                    <MudTh>Solicitud</MudTh>
                    <MudTh>N° Expediente</MudTh>
                    <MudTh>Solicitante</MudTh>
                    <MudTh>NroAutorizacion</MudTh>
                    <MudTh>FechaVigencia</MudTh>
                    <MudTh>Fec.Registro</MudTh>
                    <MudTh>Doc.Especialista</MudTh>
                    <MudTh>EstadoTramite</MudTh>
                    <MudTh class="text-center"></MudTh>
                </HeaderContent>

                <RowTemplate>
                    <MudTd Style="font-size:11px">@context.tipoUbicacion</MudTd>
                    <MudTd Style="font-size:11px">@context.nroExpediente - @context.fechaExpediente</MudTd>
                    <MudTd Style="font-size:11px">@context.solicitante</MudTd>
                    <MudTd Style="font-size:11px">@context.nroAutorizacion - @context.fechaAutorizacion</MudTd>
                    <MudTd Style="font-size:11px">@context.fechaVigencia</MudTd>
                    <MudTd Style="font-size:11px">@context.fechaRegistro</MudTd>
                    <MudTd Style="font-size:11px">@context.nroInformeEsp</MudTd>
                    <MudTd Style="font-size:11px">@context.descripcionEstado</MudTd>

                    <MudTd Class="text-center">
                        <MudTooltip Text="Informacion">
                            <MudIconButton Icon="@Icons.Material.Filled.Book"
                                           Style="@($"color:{Colors.Purple.Accent3};")"
                                           Size="Size.Small"
                                           Class="ms-1"
                                           OnClick="() => getDialogDetalle(context.idAnuncio)" />
                        </MudTooltip>
                        <MudTooltip Text="Actualizar">
                            <MudIconButton Icon="@Icons.Material.Filled.InsertDriveFile"
                                           Color="Color.Info"
                                           Size="Size.Small"
                                           Class="ms-1"
                                           OnClick="() => getDialogResolucion(context.idAnuncio)" />
                        </MudTooltip>
                        <!--
                        <MudTooltip Text="Abrir Carpeta">
                            <MudIconButton Icon="@Icons.Material.Filled.FolderOpen"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           Class="ms-1"
                                           OnClick="() => GetDialogDocument2(context.idAnuncio)" />
                        </MudTooltip>
                        -->
                        <!--OnClick="() => MostrarDialogoDesactivar(context.idAnuncio)"-->
                        <MudTooltip Text="Anular">
                            <MudIconButton Icon="@Icons.Material.Filled.Cancel"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           Class="ms-1"
                                           Disabled="@isBtnDisable"
                                           OnClick="AbrirDialogEstados" />
                        </MudTooltip>

                    </MudTd>
                </RowTemplate>

                <PagerContent>
                    <MudTablePager PageSizeOptions="new int[] { 10, 20, 50 }" />
                </PagerContent>
            </MudTable>

        }
        else {
            <MudAlert Severity="Severity.Info" Variant="Variant.Filled" Class="text-center">
                No se encontraron registros pendientes.
            </MudAlert>
        }
    </MudPaper>
</MudContainer>


<style>
    
    .tabla-chica {
        font-size: 11px; /* Cambia según quieras */
    }
</style>