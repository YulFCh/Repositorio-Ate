@using MudBlazor
@inject IDialogService DialogService
@inject IGirosService GiroService
@using SistemaLicencias.SHARED.DTOs
@using SISFRONT.Components.Utilities;
@using SISFRONT.Components.Dialogs;


<MudPaper Class="p-4 rounded-lg">
    <MudText Typo="Typo.h6">Listado de Giros Complementarios</MudText>

    <MudTable Items="giroC" Dense="true" Hover="true" Bordered="true">
        <HeaderContent>
            <MudTh>ID</MudTh>
            <MudTh>Nombre</MudTh>
            <MudTh>Estado</MudTh>
            <MudTh></MudTh>
        </HeaderContent>
        <RowTemplate>
            <MudTd>@context.IdGiroComplementario</MudTd>
            <MudTd>@context.Nombre</MudTd>
            <MudTd>
                <MudChip T="string" Color="@(context.estado == 1 ? Color.Success : Color.Error)">
                    @(context.estado == 1 ? "Activo" : "Inactivo")
                </MudChip>
            </MudTd>
            <MudTd>
                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                               Color="Color.Primary"
                               OnClick="@(() => AbrirDialogoEditar(context))" />
                <!--<MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" />-->
            </MudTd>
        </RowTemplate>
        <PagerContent>
            <MudTablePager PageSizeOptions="new int[] { 10,15,20, 50 }" />
        </PagerContent>
    </MudTable>
</MudPaper>

@code {
    private List<GiroComplementario> giroC = new();

    protected override async Task OnInitializedAsync() {
        await LoadComboComplementario();
    }

    private async Task LoadComboComplementario() {
        giroC = await GiroService.ObtenerGirosPorTipoAsync<GiroComplementario>(2);
    }

    private async Task AbrirDialogoEditar(GiroComplementario comp) {

        GiroFlexible rs = new GiroFlexible {
                TipoRegistro = 2,               
                Nombre = comp.Nombre,
                Estado = comp.estado,
                IdGiroComplementario = comp.IdGiroComplementario,
                IdGiroPrincipal = comp.IdGiroPrincipal
            };

        var parameters = new DialogParameters {
                ["giroFlex"] = rs,
            };

        var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true };

        var dialog = DialogService.Show<DialogGiros>("Editar Giro Complementario", parameters, options);

        var result = await dialog.Result;

        if(!result.Canceled) {
            await LoadComboComplementario(); // recarga la tabla
        }
    }

}

