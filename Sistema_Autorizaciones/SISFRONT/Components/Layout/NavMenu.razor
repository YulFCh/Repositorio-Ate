@inject SessionService session


<MudNavMenu>
    <MudImage Src="img/logoblanco.png"
              Class="w-100 px-2 pt-2 mx-auto d-block"
              Style="height: auto; max-height: 90px;" />

    <MudDivider Class="my-2" />

    @foreach(var item in NavItems) {
        if(item.Children?.Any() == true) {
            <MudNavGroup Title="@item.Title" Icon="@item.Icon" Expanded="true">
                @foreach(var child in item.Children) {
                    if(child.Children?.Any() == true) {
                        <MudNavGroup Title="@child.Title" Icon="@child.Icon">
                            @foreach(var grand in child.Children) {
                                <MudNavLink Href="@grand.Href" Icon="@grand.Icon">@grand.Title</MudNavLink>
                            }
                        </MudNavGroup>
                    }
                    else {
                        <MudNavLink Href="@child.Href" Icon="@child.Icon">@child.Title</MudNavLink>
                    }
                }
            </MudNavGroup>
        }
        else {
            <MudNavLink Href="@item.Href" Icon="@item.Icon">@item.Title</MudNavLink>
        }
    }
</MudNavMenu>


